APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8001
APP_BASE_URL=https://animha.co.in
APP_FORCE_HTTPS=false
APP_TRUSTED_HOSTS=animha.co.in,www.animha.co.in,127.0.0.1,localhost
APP_FORWARDED_ALLOW_IPS=*

APP_AUTH_ENABLED=true
APP_COOKIE_SECURE=true
APP_SESSION_TTL_MINUTES=720
APP_SESSION_SECRET=replace-with-a-long-random-secret
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=
APP_ADMIN_PASSWORD_HASH=replace-with-output-from-gigoptimizer-security-hash-password

APP_DOMAIN=animha.co.in
SSL_EMAIL=you@example.com

POSTGRES_DB=gigoptimizer
POSTGRES_USER=gigoptimizer
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql+psycopg://gigoptimizer:replace-with-a-strong-database-password@postgres:5432/gigoptimizer

REDIS_URL=redis://redis:6379/0
JOB_QUEUE_EAGER=false
RQ_QUEUE_NAME=gigoptimizer
RQ_SCHEDULER_QUEUE_NAME=gigoptimizer-scheduler
JOB_PROGRESS_CHANNEL=gigoptimizer:events

DATA_DIR=data
REPORTS_DIR=reports
INTEGRATION_SETTINGS_PATH=data/integrations.json
DEFAULT_SNAPSHOT_PATH=examples/wordpress_speed_snapshot.json
FRONTEND_DIST_DIR=frontend/dist

SENTRY_DSN=
BROWSERLESS_ENABLED=false
BROWSERLESS_WS_URL=
BROWSERLESS_API_TOKEN=

MARKETPLACE_ENABLED=true
MARKETPLACE_SEARCH_TERMS=wordpress speed,core web vitals,woocommerce speed
MARKETPLACE_MY_GIG_URL=
GOOGLE_TRENDS_TIMEFRAME=today 3-m
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us
SERPAPI_API_KEY=
FIVERR_ANALYTICS_URL=
FIVERR_EMAIL=
FIVERR_PASSWORD=
FIVERR_STORAGE_STATE_PATH=playwright/.auth/fiverr-state.json
FIVERR_MARKETPLACE_MAX_RETRIES=3
FIVERR_MARKETPLACE_RETRY_BASE_DELAY_SECONDS=2
FIVERR_MARKETPLACE_REQUEST_DELAY_MS=1500
FIVERR_MARKETPLACE_PROFILE_DIR=playwright/.marketplace-profile
FIVERR_MARKETPLACE_VERIFICATION_TIMEOUT_SECONDS=600

EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=
EMAIL_TO_ADDRESSES=
EMAIL_USE_TLS=true
SLACK_WEBHOOK_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT_NUMBER=
WHATSAPP_API_VERSION=v23.0

AI_PROVIDER=n8n
AI_MODEL=gigoptimizer-n8n-webhook
AI_API_KEY=
AI_API_BASE_URL=http://n8n:5678/webhook/gigoptimizer-assistant

HOSTINGER_ENABLED=false
HOSTINGER_API_BASE_URL=https://developers.hostinger.com
HOSTINGER_API_TOKEN=
HOSTINGER_VIRTUAL_MACHINE_ID=
HOSTINGER_PROJECT_NAME=deploy
HOSTINGER_DOMAIN=animha.co.in
HOSTINGER_METRICS_WINDOW_MINUTES=60
HOSTINGER_REQUEST_TIMEOUT_SECONDS=20

COPILOT_LEARNING_ENABLED=true
COPILOT_LEARNING_INTERVAL_MINUTES=30

EXTENSION_ENABLED=true
EXTENSION_API_TOKEN=replace-with-a-long-random-extension-token
EXTENSION_MAX_GIGS_PER_IMPORT=25
EXTENSION_IMPORT_TTL_SECONDS=900
