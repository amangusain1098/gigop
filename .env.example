GOOGLE_TRENDS_GEO=
GOOGLE_TRENDS_TIMEFRAME=today 3-m
GOOGLE_TRENDS_HL=en-US
GOOGLE_TRENDS_TZ=330
GOOGLE_TRENDS_MAX_QUERIES=5

SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us
SEMRUSH_TIMEOUT_SECONDS=30
SERPAPI_API_KEY=
SERPAPI_ENGINE=google
SERPAPI_NUM_RESULTS=10
MARKETPLACE_READER_ENABLED=true
MARKETPLACE_READER_BASE_URL=https://r.jina.ai/http://

FIVERR_LOGIN_URL=https://www.fiverr.com/login
FIVERR_ANALYTICS_URL=
FIVERR_EMAIL=
FIVERR_PASSWORD=
FIVERR_STORAGE_STATE_PATH=playwright/.auth/fiverr-state.json
FIVERR_HEADLESS=true

# Tune these selectors to your seller dashboard if Fiverr updates the DOM.
FIVERR_EMAIL_SELECTOR=input[type="email"], input[name="username"]
FIVERR_PASSWORD_SELECTOR=input[type="password"]
FIVERR_SUBMIT_SELECTOR=button[type="submit"]
FIVERR_IMPRESSIONS_SELECTOR=[data-testid="analytics-impressions"]
FIVERR_CLICKS_SELECTOR=[data-testid="analytics-clicks"]
FIVERR_ORDERS_SELECTOR=[data-testid="analytics-orders"]
FIVERR_SAVES_SELECTOR=[data-testid="analytics-saves"]
FIVERR_RESPONSE_TIME_SELECTOR=[data-testid="analytics-response-time"]
FIVERR_MARKETPLACE_SEARCH_URL_TEMPLATE=https://www.fiverr.com/search/gigs?query={query}
FIVERR_MARKETPLACE_CARD_SELECTOR=article
FIVERR_MARKETPLACE_TITLE_SELECTOR=h3, [data-testid="gig-card-title"]
FIVERR_MARKETPLACE_PRICE_SELECTOR=[data-testid="gig-card-price"], [class*="price"]
FIVERR_MARKETPLACE_RATING_SELECTOR=[data-testid="gig-card-rating"], [class*="rating"]
FIVERR_MARKETPLACE_REVIEWS_SELECTOR=[data-testid="gig-card-reviews"], [class*="reviews"]
FIVERR_MARKETPLACE_LINK_SELECTOR=a[href*="/gig/"], a[href*="/services/"]
FIVERR_MARKETPLACE_SELLER_SELECTOR=[data-testid="seller-name"], [class*="seller"]
FIVERR_MARKETPLACE_BADGE_SELECTOR=[data-testid="seller-level"], [class*="badge"], [class*="level"]
FIVERR_MARKETPLACE_SNIPPET_SELECTOR=p, [data-testid="gig-card-description"]
FIVERR_MARKETPLACE_DELIVERY_SELECTOR=[data-testid="delivery-time"], [class*="delivery"]
FIVERR_MARKETPLACE_MAX_RESULTS=12
FIVERR_MARKETPLACE_PROFILE_DIR=playwright/.marketplace-profile
FIVERR_MARKETPLACE_VERIFICATION_TIMEOUT_SECONDS=600
FIVERR_MARKETPLACE_HEADLESS=false
FIVERR_MARKETPLACE_BROWSER_CHANNEL=auto
FIVERR_MARKETPLACE_SLOW_MO_MS=250

APPROVAL_QUEUE_DB_PATH=data/approval_queue.db
INTEGRATION_SETTINGS_PATH=data/integrations.json

# Hosted dashboard authentication
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8001
APP_BASE_URL=
APP_FORCE_HTTPS=false
APP_TRUSTED_HOSTS=
APP_FORWARDED_ALLOW_IPS=*
APP_AUTH_ENABLED=false
APP_COOKIE_SECURE=false
APP_SESSION_TTL_MINUTES=720
APP_SESSION_SECRET=
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=
APP_ADMIN_PASSWORD_HASH=
MARKETPLACE_ENABLED=false
MARKETPLACE_SEARCH_TERMS=
MARKETPLACE_MY_GIG_URL=

# Optional notification channel secrets
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=
EMAIL_TO_ADDRESSES=
EMAIL_USE_TLS=true
SLACK_WEBHOOK_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT_NUMBER=
WHATSAPP_API_VERSION=v23.0

# Optional AI copilot connector
AI_PROVIDER=n8n
AI_MODEL=gigoptimizer-n8n-webhook
AI_API_KEY=
AI_API_BASE_URL=http://n8n:5678/webhook/gigoptimizer-assistant

HOSTINGER_ENABLED=false
HOSTINGER_API_BASE_URL=https://developers.hostinger.com
HOSTINGER_API_TOKEN=
HOSTINGER_VIRTUAL_MACHINE_ID=
HOSTINGER_PROJECT_NAME=
HOSTINGER_DOMAIN=
HOSTINGER_METRICS_WINDOW_MINUTES=60
HOSTINGER_REQUEST_TIMEOUT_SECONDS=20
