            }
          ]
        }
      },
      "id": "n8n-node-fetch-stats",
      "name": "Fetch Learning Stats",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        460,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
