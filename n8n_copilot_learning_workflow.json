    {
      "parameters": {
        "url": "http://deploy-app-1:8001/api/copilot/training-dashboard/predict?q=fiverr&top_n=5",
        "options": {
          "timeout": 10000
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-API-Key",
              "value": "EbKgctxIFDm2o5-7sOguaWS84xUSIdeyRMZsd-D_pRc"
            }
          ]
        }
      },
      "id": "n8n-node-fetch-predict",
      "name": "Fetch Word Predictions (sample)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        460,
        480
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "gigoptimizer-cookie",
          "name": "GigOptimizer Session Cookie"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const stats   = $('Fetch Learning Stats').first().json;\nconst predict = $('Fetch Word Predictions (sample)').first().json;\n\nconst model    = stats.model   || {};\nconst totals   = stats.totals  || {};\nconst schedule = stats.schedule || {};\nconst tests    = stats.test_results || {};\nconst recent   = (stats.recent_learning || []).slice(0, 5);\nconst comps    = (predict.completions   || []).slice(0, 5);\n\nconst testIcon = { pass: '\u2705', fail: '\u274c', error: '\u26a0\ufe0f', never_run: '\u2b1c' }[tests.status] || '\u2b1c';\n\nconst recentLines = recent.map(ev => {\n  const src  = ev.source || '?';\n  const toks = ev.tokens_learned ? ` +${ev.tokens_learned} tokens` : '';\n  const ts   = (ev.timestamp || '').slice(0, 16).replace('T', ' ');\n  return `\u2022 ${ts}  \\`${src}\\`${toks}`;\n}).join('\\n') || '_No recent events_';\n\nconst compLines = comps.map(c =>\n  `\u2022 \\`${c.full_suggestion}\\`  _(score ${c.score})_`\n).join('\\n') || '_No predictions yet \u2014 ingest more data_';\n\nconst nextRun = schedule.next_run\n  ? schedule.next_run.slice(0, 16).replace('T', ' ')\n  : 'not scheduled';\n\nreturn [{\n  json: {\n    vocab_size:    model.vocab_size    || 0,\n    doc_count:     model.doc_count     || 0,\n    bigram_count:  model.bigram_count  || 0,\n    total_tokens:  totals.total_tokens || 0,\n    total_new_words: totals.total_new_words || 0,\n    cron_cycles:   schedule.run_count  || 0,\n    schedule_enabled: schedule.enabled ? '\ud83d\udfe2 Active' : '\ud83d\udd34 Paused',\n    next_run:      nextRun,\n    test_status:   tests.status        || 'never_run',\n    test_passed:   tests.passed        || 0,\n    test_total:    tests.total         || 0,\n    test_icon:     testIcon,\n    recent_lines:  recentLines,\n    comp_lines:    compLines,\n    version:       stats.version       || '?',\n  }\n}];\n"
      },
      "id": "n8n-node-transform",
      "name": "Build Digest Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        380
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-tests",
              "leftValue": "={{ $json.test_status }}",
              "rightValue": "fail",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "or"
        }
      },
      "id": "n8n-node-check-fail",
      "name": "Tests Failing?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        920,
        380
      ]
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "={{ $vars.SLACK_CHANNEL_ID }}",
          "mode": "id"
        },
        "text": "",
        "blocksUi": {
          "blocksValues": [
            {
              "type": "header",
              "text": {
                "type": "plain_text",
                "text": "\ud83e\udde0 GigOptimizer Copilot \u2014 4-Hour Learning Digest",
                "emoji": true
              }
            },
            {
              "type": "section",
              "fields": [
                {
                  "type": "mrkdwn",
                  "text": "*Vocabulary*\n={{ $json.vocab_size.toLocaleString() }} words"
                },
                {
                  "type": "mrkdwn",
                  "text": "*Docs ingested*\n={{ $json.doc_count }}"
                },
                {
                  "type": "mrkdwn",
                  "text": "*Tokens learned*\n={{ $json.total_tokens.toLocaleString() }}"
                },
                {
                  "type": "mrkdwn",
                  "text": "*New words*\n={{ $json.total_new_words.toLocaleString() }}"
                },
                {
                  "type": "mrkdwn",
                  "text": "*Bigrams*\n={{ $json.bigram_count.toLocaleString() }}"
                },
                {
                  "type": "mrkdwn",
                  "text": "*Cron cycles*\n={{ $json.cron_cycles }}"
                }
              ]
            },
            {
              "type": "section",
              "fields": [
                {
                  "type": "mrkdwn",
                  "text": "*Tests* ={{ $json.test_icon }}\n={{ $json.test_passed }}/={{ $json.test_total }} passed"
                },
                {
                  "type": "mrkdwn",
                  "text": "*Schedule*\n={{ $json.schedule_enabled }}"
                },
                {
                  "type": "mrkdwn",
                  "text": "*Next training run*\n={{ $json.next_run }}"
                },
                {
                  "type": "mrkdwn",
                  "text": "*Model version*\nv={{ $json.version }}"
                }
              ]
            },
            {
              "type": "section",
              "text": {
                "type": "mrkdwn",
                "text": "*Recent learning events*\n={{ $json.recent_lines }}"
              }
            },
            {
              "type": "section",
              "text": {
                "type": "mrkdwn",
                "text": "*Sample predictions for \"fiverr\u2026\"*\n={{ $json.comp_lines }}"
              }
            },
            {
              "type": "divider"
            }
          ]
        },
        "otherOptions": {
          "mrkdwn": true
        },
        "url": "YOUR_SLACK_WEBHOOK_URL"
      },
