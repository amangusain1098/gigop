    {
      "parameters": {
        "method": "POST",
        "url": "YOUR_SLACK_WEBHOOK_URL",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"text\": \"*GigOptimizer Copilot \u2014 Learning Digest*\",\n  \"blocks\": [\n    {\n      \"type\": \"header\",\n      \"text\": { \"type\": \"plain_text\", \"text\": \"\ud83e\udd16 Copilot Learning Digest\" }\n    },\n    {\n      \"type\": \"section\",\n      \"fields\": [\n        { \"type\": \"mrkdwn\", \"text\": \"*Total Tokens:*\\n{{ $json.vocab_model.total_tokens }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*Vocab Size:*\\n{{ $json.vocab_model.vocab_size }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*Training Runs:*\\n{{ $json.learning_stats.training_runs }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*Test Status:*\\n{{ $json.test_results.status }}\" }\n      ]\n    },\n    {\n      \"type\": \"section\",\n      \"text\": { \"type\": \"mrkdwn\", \"text\": \"*Last Updated:* {{ $json.vocab_model.last_updated }}\" }\n    }\n  ]\n}"
      },
