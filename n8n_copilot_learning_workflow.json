          },
          "conditions": [
            {
              "id": "cond-tests",
              "leftValue": "={{ $json.test_status }}",
              "rightValue": "fail",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "or"
        }
      },
